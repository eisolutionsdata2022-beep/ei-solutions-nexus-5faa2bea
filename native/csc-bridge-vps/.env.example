# Generate with: openssl rand -hex 32
HMAC_SECRET=replace-me-with-32-byte-hex

# Port the Express server listens on (nginx proxies to this)
PORT=8787

# Optional: override Chromium path if puppeteer download is disabled
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Optional: skew tolerance (seconds) for X-Timestamp validation
HMAC_MAX_SKEW_SEC=300

# Headless mode for Puppeteer (set to "false" to debug visually with X server)
HEADLESS=true

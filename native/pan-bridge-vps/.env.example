# EI SOLUTIONS — PAN Bridge VPS
# Copy to .env and fill in the values.

# Port the bridge listens on. Nginx terminates TLS and proxies here.
PORT=8788

# Shared HMAC secret. Must match the value encrypted via Admin →
# PAN Settings → "VPS Bridge Secret". Min 32 chars recommended.
HMAC_SECRET=replace-with-a-long-random-string-min-32-chars

# Reject requests with timestamps older than this (seconds). Default 300.
HMAC_MAX_SKEW_SEC=300

# Restrict which upstream hosts the bridge will forward to. Comma-separated.
# Defaults to mallikacyberzone.com only.
ALLOWED_HOSTS=mallikacyberzone.com,www.mallikacyberzone.com

# Optional: comma-separated CIDRs for trusted client IPs (extra defence beyond
# HMAC). Leave blank to allow any source as long as HMAC validates.
ALLOWED_CLIENT_CIDRS=

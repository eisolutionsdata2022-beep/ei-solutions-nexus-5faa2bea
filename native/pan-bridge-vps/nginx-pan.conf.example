## EI SOLUTIONS — PAN Bridge nginx config
##
## 1. Replace pan-bridge.eisoluions.xyz with your own subdomain.
## 2. Point an A-record at this VPS's public IP. That same IP must be
##    whitelisted in the mallikacyberzone Developer API → IP Address page.
## 3. Run `certbot --nginx -d pan-bridge.eisoluions.xyz` to provision TLS.

server {
    listen 80;
    server_name pan-bridge.eisoluions.xyz;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name pan-bridge.eisoluions.xyz;

    # Managed by certbot
    ssl_certificate     /etc/letsencrypt/live/pan-bridge.eisoluions.xyz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/pan-bridge.eisoluions.xyz/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Modest body size — PAN payloads are tiny.
    client_max_body_size 64k;

    # Gzip on JSON
    gzip on;
    gzip_types application/json;

    # Health check (public)
    location = /health {
        proxy_pass http://127.0.0.1:8788/health;
    }

    # Proxy endpoint
    location /proxy/ {
        proxy_pass http://127.0.0.1:8788;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Forward HMAC headers
        proxy_set_header X-Signature  $http_x_signature;
        proxy_set_header X-Timestamp  $http_x_timestamp;

        proxy_read_timeout 60s;
        proxy_connect_timeout 10s;
    }

    location / {
        return 404;
    }
}

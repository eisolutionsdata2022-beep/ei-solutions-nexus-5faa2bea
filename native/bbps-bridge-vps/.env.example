# Generate with: openssl rand -hex 32
HMAC_SECRET=replace-me-with-32-byte-hex

# Port the Express server listens on (nginx proxies to this)
PORT=8788

# Provider base URL (UAT by default — switch to prod when go-live)
BBPS_BASE_URL=https://aceneobank.dev.acepe.co.in/apiService

# Optional: skew tolerance (seconds) for X-Timestamp validation
HMAC_MAX_SKEW_SEC=300

# Optional: outbound request timeout (ms)
PROVIDER_TIMEOUT_MS=45000

# ─── HMAC ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must match Lovable secret WA_BRIDGE_HMAC_SECRET
HMAC_SECRET=replace-me-with-32-byte-hex

# ─── Server ────────────────────────────────────────────────────────────
PORT=8788
HMAC_MAX_SKEW_SEC=300

# ─── Firestore Admin ───────────────────────────────────────────────────
# Path to service account JSON downloaded from Firebase console:
#   Project Settings → Service Accounts → Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=/opt/whatsapp-bridge/firebase-service-account.json
FIREBASE_PROJECT_ID=ei-fix

# ─── WhatsApp Web client ───────────────────────────────────────────────
# Friendly name for this device (shown in WhatsApp linked-devices list)
WA_CLIENT_NAME=EI Solutions Portal
# Persistent session directory (whatsapp-web.js LocalAuth)
WA_SESSION_DIR=/opt/whatsapp-bridge/.wwebjs_auth
# Headless puppeteer (set to "false" to debug visually)
HEADLESS=true
# Optional: override Chromium path
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ─── Bulk safety limits (HARD CAPS — DO NOT INCREASE) ──────────────────
# WhatsApp Web bridge gets banned fast if you exceed these.
WA_RATE_PER_MIN=5
WA_RATE_PER_DAY=100
# Min/max delay (ms) between bulk sends — randomized to look human
WA_SEND_DELAY_MIN_MS=8000
WA_SEND_DELAY_MAX_MS=18000

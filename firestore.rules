rules_version = '2';

// =====================================================================
// EI Solutions — Firestore Security Rules (baseline + targeted hardening)
// =====================================================================

service cloud.firestore {
  match /databases/{db}/documents {

    function isAuthed() { return request.auth != null; }
    function role()     { return get(/databases/$(db)/documents/users/$(request.auth.uid)).data.role; }
    function isAdmin()  { return isAuthed() && role() == "admin"; }

    // Hardened collections — admin-only (contain secrets / master config).
    match /csc_config/{doc}  { allow read, write: if isAdmin(); }
    match /pan_config/{doc}  { allow read, write: if isAdmin(); }

    // psa_ids — owner or admin only (prevents enumerating other users' PSA IDs).
    match /psa_ids/{uid} {
      allow read:   if isAuthed() && (uid == request.auth.uid || isAdmin());
      allow create: if isAuthed() && uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Public-write allowlist for landing-page lead capture (anonymous visitors).
    match /crmLeads/{leadId} {
      function validPublicLead() {
        let d = request.resource.data;
        return d.leadSource == "Landing Page"
            && d.status == "New"
            && d.createdBy == "landing-page"
            && d.name is string  && d.name.size() >= 2 && d.name.size() <= 80
            && d.phone is string && d.phone.matches('^[6-9][0-9]{9}$');
      }
      allow create: if isAuthed() || validPublicLead();
      allow read, list, update: if isAuthed();
      allow delete: if isAdmin();
    }

    // Rewards Wallet — owner read, admin-only write (server/admin actions only).
    // Retailers can READ their own balance & ledger; only admin can credit/debit
    // (referral/game credits go through admin SDK or server functions, transfer
    //  approvals run from admin UI signed in as admin).
    match /rewardsWallets/{uid} {
      allow read:  if isAuthed() && (uid == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    match /rewardsLedger/{entryId} {
      allow read:   if isAuthed() && (resource.data.uid == request.auth.uid || isAdmin());
      allow list:   if isAuthed();
      allow write:  if isAdmin();
    }
    match /rewardsTransferRequests/{reqId} {
      // Owner can create their own request and read it; admin can do everything.
      allow read, list: if isAuthed() && (resource == null || resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthed()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.status == "pending";
      allow update, delete: if isAdmin();
    }

    // ---------------------------------------------------------------
    // Default — any authenticated user can read/write everything else.
    // (Migrate individual collections to stricter rules over time.)
    // ---------------------------------------------------------------
    match /{document=**} {
      allow read, write: if isAuthed();
    }
  }
}

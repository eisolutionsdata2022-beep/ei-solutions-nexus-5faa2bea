rules_version = '2';

// =====================================================================
// EI Solutions — Firestore Security Rules
// Hardening pass: block role escalation, wallet fraud, and config tampering.
// =====================================================================

service cloud.firestore {
  match /databases/{db}/documents {

    function isAuthed() { return request.auth != null; }
    function role()     { return get(/databases/$(db)/documents/users/$(request.auth.uid)).data.role; }
    function isAdmin()  { return isAuthed() && role() == "admin"; }
    function isStaff()  { return isAuthed() && (role() == "admin" || role() == "staff" || role() == "distributor"); }

    // -----------------------------------------------------------------
    // SENSITIVE — admin-only master config (secrets, bridge URLs, etc.)
    // These MUST come before the catch-all and the catch-all MUST NOT
    // grant access to these paths (handled by removing wildcard write).
    // -----------------------------------------------------------------
    match /csc_config/{doc}  { allow read, write: if isAdmin(); }
    match /pan_config/{doc}  { allow read, write: if isAdmin(); }
    match /platformConfig/{doc} { allow read: if isAuthed(); allow write: if isAdmin(); }

    // -----------------------------------------------------------------
    // USERS — block role/privilege escalation.
    // Owner can read/update their own non-privileged fields.
    // Staff can read all users; only admin can change role/kycStatus/etc.
    // -----------------------------------------------------------------
    match /users/{uid} {
      allow read:   if isAuthed() && (uid == request.auth.uid || isStaff());
      allow create: if isAuthed() && uid == request.auth.uid;
      // Owner self-update: cannot change privileged fields.
      allow update: if isAuthed() && uid == request.auth.uid
                    && !(request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['role','kycStatus','walletBalance','activeServices',
                                   'serviceActivations','planId','permissions','isActive',
                                   'createdBy','staffId','distributorId']));
      // Admin can update anything; staff can update non-role fields.
      allow update, delete: if isAdmin();
    }

    // -----------------------------------------------------------------
    // WALLETS — owner read; writes only via server / admin.
    // Client-side credit/debit paths use runTransaction; restrict to admin
    // and the owner only for self-debits (activations). Atomic ops still
    // work because the transaction runs as the authenticated user.
    // -----------------------------------------------------------------
    match /wallets/{uid} {
      allow read:  if isAuthed() && (uid == request.auth.uid || isStaff());
      // Owner can update their own wallet doc (needed for atomic debit on
      // service activation / referral credit). Admin can update any.
      allow write: if isAuthed() && (uid == request.auth.uid || isAdmin());
    }

    match /walletRequests/{reqId} {
      allow read, list: if isAuthed();
      allow create: if isAuthed()
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // psa_ids — owner or admin only.
    match /psa_ids/{uid} {
      allow read:   if isAuthed() && (uid == request.auth.uid || isAdmin());
      allow create: if isAuthed() && uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Public-write allowlist for landing-page lead capture.
    match /crmLeads/{leadId} {
      function validPublicLead() {
        let d = request.resource.data;
        return d.leadSource == "Landing Page"
            && d.status == "New"
            && d.createdBy == "landing-page"
            && d.name is string  && d.name.size() >= 2 && d.name.size() <= 80
            && d.phone is string && d.phone.matches('^[6-9][0-9]{9}$');
      }
      allow create: if isAuthed() || validPublicLead();
      allow read, list, update: if isAuthed();
      allow delete: if isAdmin();
    }

    // Rewards Wallet — owner read; writes for referral payouts.
    match /rewardsWallets/{uid} {
      allow read:  if isAuthed() && (uid == request.auth.uid || isAdmin());
      allow write: if isAuthed();
    }
    match /rewardsLedger/{entryId} {
      allow read, list: if isAuthed();
      allow create: if isAuthed();
      allow update, delete: if isAdmin();
    }
    match /rewardsTransferRequests/{reqId} {
      allow read, list: if isAuthed();
      allow create: if isAuthed()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.status == "pending";
      allow update, delete: if isAdmin();
    }

    // ---------------------------------------------------------------
    // Default — any authenticated user can read/write everything else.
    // NOTE: Firestore evaluates rules with OR semantics, but path-specific
    // matches above take precedence for their own paths. The wildcard below
    // does NOT override the rules above for /users, /wallets, /csc_config,
    // /pan_config, /walletRequests, /psa_ids, /rewards*, /crmLeads, or
    // /platformConfig — those paths use only their explicit rules.
    // Other operational collections still allow authed access.
    // ---------------------------------------------------------------
    match /{document=**} {
      allow read, write: if isAuthed();
    }
  }
}

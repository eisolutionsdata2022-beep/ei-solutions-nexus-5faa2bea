rules_version = '2';

// =====================================================================
// EI Solutions — Firestore Security Rules
// ---------------------------------------------------------------------
// Deploy with:  firebase deploy --only firestore:rules
// =====================================================================

service cloud.firestore {
  match /databases/{db}/documents {

    // ---------- helpers ---------------------------------------------
    function isAuthed()    { return request.auth != null; }
    function role()        { return get(/databases/$(db)/documents/users/$(request.auth.uid)).data.role; }
    function isAdmin()     { return isAuthed() && role() == "admin"; }
    function isStaffish()  { return role() in ["staff","manager","admin"]; }
    function isRetailer()  { return role() == "retailer"; }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ---------- ippbRequests ----------------------------------------
    match /ippbRequests/{rid} {
      allow read:   if isAuthed() && (
                      resource.data.retailerId == request.auth.uid
                   || resource.data.staffId    == request.auth.uid
                   || isStaffish());
      allow create: if isAuthed() && isRetailer()
                    && request.resource.data.retailerId == request.auth.uid
                    && request.resource.data.status == "pending";
      allow update: if isAuthed() && (
                      (resource.data.staffId    == request.auth.uid && isStaffish())
                   || (resource.data.retailerId == request.auth.uid));
      allow delete: if false;

      match /captureRequests/{cid} {
        allow create: if isAuthed() && isStaffish()
                      && request.resource.data.staffId == request.auth.uid;
        allow read:   if isAuthed() && (
                        resource.data.retailerId == request.auth.uid
                     || resource.data.staffId    == request.auth.uid);
        allow update: if isAuthed() && (
                        (resource.data.staffId    == request.auth.uid
                         && request.resource.data.status == "cancelled")
                     || (resource.data.retailerId == request.auth.uid
                         && request.resource.data.status in
                            ["capturing","captured","failed"]));
        allow delete: if false;
      }
    }

    // ---------- interceptorCaptures ---------------------------------
    match /interceptorCaptures/{cid} {
      allow read: if isAuthed() && (
                    resource.data.staffId    == request.auth.uid
                 || resource.data.retailerId == request.auth.uid
                 || isStaffish());

      allow create: if isAuthed()
                    && request.resource.data.staffId == request.auth.uid
                    && request.resource.data.status == "requested"
                    && request.resource.data.mode in ["capture","detection"];

      function retailerUpdateOk() {
        return resource.data.retailerId == request.auth.uid
            && request.resource.data.status in
               ["capturing","captured","acknowledged","failed","timeout"]
            && changedKeys().hasOnly([
                 "status","pidXml","hash","deviceModel",
                 "errorMessage","completedAt","retailerId"
               ]);
      }

      function staffCancelOk() {
        return resource.data.staffId == request.auth.uid
            && request.resource.data.status == "cancelled"
            && changedKeys().hasOnly(["status","cancelledAt"]);
      }

      allow update: if isAuthed() && (retailerUpdateOk() || staffCancelOk());
      allow delete: if false;
    }

    // ---------- csc_config (EI SOLUTIONS PAY) -----------------------
    // Encrypted master CSC credentials + bridge config + service flags.
    // Admin-only read/write. Retailers MUST NOT read this — the cipher
    // and HMAC secret are passed to the server function, never the
    // client.
    //
    // NOTE: The retailer execution flow currently fetches this doc
    // client-side. To preserve that flow without exposing secrets,
    // store cipher/url/secret in a sub-doc that only admins can read,
    // OR move the bridge dispatch fully server-side. For now we keep
    // legacy behaviour but lock writes to admin and reads to admin
    // (retailer flow must be migrated to a server fn).
    match /csc_config/{doc} {
      allow read, write: if isAdmin();
    }

    // ---------- csc_transactions ------------------------------------
    // Retailer can read own transactions, admin can read all.
    // Create allowed for the retailer themselves (server validates
    // amounts via wallet debit). Updates only by the retailer who
    // created the doc (to flip status to success/refunded after the
    // bridge call). No deletes.
    match /csc_transactions/{tx} {
      allow read: if isAuthed() && (
                    resource.data.retailerId == request.auth.uid
                 || isAdmin());
      allow create: if isAuthed()
                    && request.resource.data.retailerId == request.auth.uid
                    && request.resource.data.status in ["pending","processing"];
      allow update: if isAuthed()
                    && resource.data.retailerId == request.auth.uid
                    && changedKeys().hasOnly([
                         "status","bridgeRef","bridgeResponse",
                         "errorMessage","completedAt"
                       ]);
      allow delete: if false;
    }

    // ---------- DMT (Domestic Money Transfer) -----------------------
    // Retailer owns customers + beneficiaries; staff/admin can read all
    // for processing the transfer queue. Transfers are created by the
    // retailer; staff/admin update status (processing/success/failed/
    // refunded). Config is admin-only write, public read for live
    // pricing on retailer side.

    match /config/dmt {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    match /dmtCustomers/{cid} {
      allow read:   if isAuthed() && (
                      resource.data.retailerId == request.auth.uid
                   || isStaffish());
      allow create: if isAuthed() && isRetailer()
                    && request.resource.data.retailerId == request.auth.uid;
      allow update: if isAuthed() && (
                      resource.data.retailerId == request.auth.uid
                   || isStaffish());
      allow delete: if isAdmin();
    }

    match /dmtBeneficiaries/{bid} {
      allow read:   if isAuthed() && (
                      resource.data.retailerId == request.auth.uid
                   || isStaffish());
      allow create: if isAuthed() && isRetailer()
                    && request.resource.data.retailerId == request.auth.uid;
      allow update: if isAuthed()
                    && resource.data.retailerId == request.auth.uid;
      allow delete: if isAuthed() && (
                      resource.data.retailerId == request.auth.uid
                   || isAdmin());
    }

    match /dmtTransfers/{tid} {
      allow read:   if isAuthed() && (
                      resource.data.retailerId == request.auth.uid
                   || isStaffish());
      allow create: if isAuthed() && isRetailer()
                    && request.resource.data.retailerId == request.auth.uid
                    && request.resource.data.status == "pending";
      allow update: if isAuthed() && (
                      isStaffish()
                   || resource.data.retailerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ---------- serviceApplications (e-District / E-dis) ------------
    // Retailer creates own applications; staff/admin process them.
    // Retailer can update their own doc post-create (to attach uploaded
    // document URLs after Firebase Storage upload completes).
    match /serviceApplications/{appId} {
      allow read:   if isAuthed() && (
                      resource.data.userId == request.auth.uid
                   || isStaffish());
      allow create: if isAuthed()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == "Pending";
      allow update: if isAuthed() && (
                      isStaffish()
                   || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}
